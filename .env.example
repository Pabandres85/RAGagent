# .env.example - Variables de entorno del sistema RAG multi-agente
# Copiar como .env y ajustar al entorno local.

# Proveedor LLM activo: lmstudio | ollama
LLM_PROVIDER=lmstudio

# LM Studio
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_API_KEY=sk-lm-XXXXXXXXXXXXXXXXXXXXXXXX
# Usa el identificador exacto expuesto por /v1/models
LM_STUDIO_MODEL=qwen2.5-7b-instruct-1m

# Ollama
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3:8b

# Parametros LLM
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=2048

# Embeddings
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
EMBEDDING_DIM=768
EMBEDDING_BATCH_SIZE=32

# FAISS
FAISS_INDEX_DIR=./artifacts/faiss
FAISS_TOP_K=10

# Datos
DATA_RAW_DIR=./data/raw
DATA_PROCESSED_DIR=./data/processed
METADATA_DIR=./data/metadata
CHUNK_SIZE=768
CHUNK_OVERLAP=128

# API
API_HOST=0.0.0.0
API_PORT=8000

# Evaluacion
GOLD_SET_PATH=./eval/datasets/gold_set.json
EVAL_OUTPUT_DIR=./artifacts/eval_runs

# Logging
LOG_LEVEL=INFO
