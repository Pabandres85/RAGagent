# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Variables de entorno del sistema RAG multi-agente
# Copiar este archivo como .env y ajustar los valores al entorno local.
# ─────────────────────────────────────────────────────────────────────────────

# ── Ollama (LLM local) ────────────────────────────────────────────────────────
# URL base del servidor Ollama
OLLAMA_BASE_URL=http://localhost:11434

# Modelo a usar: llama3:8b (recomendado) o mistral:7b
OLLAMA_MODEL=llama3:8b

# Temperatura del modelo (0.0 = determinista, recomendado para normas)
OLLAMA_TEMPERATURE=0.0

# ── Embeddings ────────────────────────────────────────────────────────────────
# Modelo de embeddings multilingüe (soporta español)
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2

# Dimensión del vector de embeddings (depende del modelo elegido)
EMBEDDING_DIM=768

# Tamaño del batch para generación de embeddings
EMBEDDING_BATCH_SIZE=32

# ── FAISS ─────────────────────────────────────────────────────────────────────
# Directorio donde se almacenan los índices FAISS por módulo
FAISS_INDEX_DIR=./artifacts/faiss

# Número de resultados a recuperar por consulta
FAISS_TOP_K=10

# ── Datos y Corpus ────────────────────────────────────────────────────────────
# Directorio con los PDFs originales de la Resolución 3100 y sus anexos
DATA_RAW_DIR=./data/raw

# Directorio con los chunks procesados (texto normalizado)
DATA_PROCESSED_DIR=./data/processed

# Directorio con los metadatos estructurados (servicio, numeral, vigencia, etc.)
METADATA_DIR=./data/metadata

# Tamaño del chunk en caracteres para la segmentación documental
CHUNK_SIZE=512

# Solapamiento entre chunks consecutivos
CHUNK_OVERLAP=64

# ── API FastAPI ───────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Evaluación ────────────────────────────────────────────────────────────────
# Ruta al gold set de 210 preguntas Q&A
GOLD_SET_PATH=./eval/datasets/gold_set.json

# Directorio de salida para resultados de evaluación
EVAL_OUTPUT_DIR=./artifacts/eval_runs

# ── Logging ───────────────────────────────────────────────────────────────────
# Nivel de log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
